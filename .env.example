# PostgreSQL (matches docker-compose defaults)
POSTGRES_USER=momentum
POSTGRES_PASSWORD=momentum_secret
POSTGRES_DB=momentumos

# Backend
PORT=3001
DATABASE_URL="postgresql://momentum:momentum_secret@localhost:5432/momentumos"
OPENAI_API_KEY=your-api-key-here

# CORS — comma-separated list of allowed frontend origins
# Dev:  http://localhost:5173
# Prod: https://your-frontend-domain.com
CORS_ORIGINS=http://localhost:5173

# Frontend (Vite — set to your production API URL for prod builds)
VITE_API_BASE_URL=http://localhost:3001
