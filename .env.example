# PostgreSQL (matches docker-compose.yml defaults)
POSTGRES_USER=momentum
POSTGRES_PASSWORD=momentum_secret
POSTGRES_DB=momentumos

# Backend
PORT=3001
DATABASE_URL="postgresql://momentum:momentum_secret@localhost:5432/momentumos"
OPENAI_API_KEY=sk-...your-key-here...

# Frontend (Vite prefix required)
VITE_API_BASE_URL=http://localhost:3001
